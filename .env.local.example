# Web3Forms (contact form + email IQ signups)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_key

# Supabase (Google sign-in + IQ result storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only — never expose in the browser or commit to git
# Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
